pipeline{
    agent {label "php"}
    
    stages{
        stage("Code Chekout..."){
            steps{
            echo "Clonig repo in sever..."
            git url: "https://github.com/pranitdhekane/Cyber-Cafe-Management.git",branch:"main"
            }
        }
        stage("building"){
            steps{
            sh "docker build -t ccms-app:latest ./ccms"
        }
        }
        stage("Pushing to DockerHub..."){
            steps{
            withCredentials([usernamePassword(credentialsId:"dockerhubcred",
            passwordVariable:"dockerhubpass",
            usernameVariable:"dockerhubusername")]){
               sh "docker image tag ccms-app:latest dpranit/ccms-app:latest"
               sh "docker login -u ${env.dockerhubusername} -p ${env.dockerhubpass}"
               sh "docker push dpranit/ccms-app:latest"
            }  
        }
        }
        stage("Deploying...."){
            steps{
            sh "docker compose up -d"
        }
        }
        
        
        
        
        
        
        
        
        
        
        
        
        
        
    }
    
    
    
    
    
}
